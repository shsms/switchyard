{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "files": {
    "includes": [
      "**",
      "!ui-assets/vendor/**",
      "!target/**",
      "!scenarios/**"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": false
  },
  "javascript": {
    "globals": [
      "vis",
      "uPlot"
    ]
  }
}
